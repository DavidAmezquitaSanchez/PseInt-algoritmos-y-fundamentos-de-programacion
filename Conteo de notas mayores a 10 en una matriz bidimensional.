Algoritmo llenar_matriz
	Dimensionar notas[3,2]
	definir i, j, contador Como real
	//pedir las notas
	para i = 1 hasta 3 Con Paso 1 Hacer
		para j = 1 hasta 2 Con Paso 1 Hacer
			Escribir "ingrese la nota del alumno ", i, " en el curso ",j," : "
			leer notas[i,j]
		FinPara
	FinPara
	//creamos el contador
	contador = 0
	//entramos al bucle anidado
	para i = 1 hasta 3 Hacer
		Para j = 1 Hasta 2 Hacer
			//(va nota por nota)si la nota es mayor a 10 
			Si notas[i,j] > 10 Entonces
				//suma 1 al contador
				contador = contador + 1
			FinSi
		FinPara
	FinPara
	
	escribir "la cantidad de notas >10, son: ", contador
FinAlgoritmo
